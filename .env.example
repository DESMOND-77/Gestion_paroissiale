# ============================================================================
# Gestion Paroissiale - variables d'environnement
# Copier ce fichier vers `.env` puis renseigner les valeurs.
# Ne JAMAIS committer le fichier `.env` (il est ignoré par .gitignore).
# ============================================================================

# --- Django core ------------------------------------------------------------
# Générer une clé : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=changez-moi-cle-secrete-longue-et-aleatoire
DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Base de données --------------------------------------------------------
# Option A : DATABASE_URL (prioritaire - utilisée sur Render / PostgreSQL)
# DATABASE_URL=postgres://user:password@host:5432/gestion_paroissiale_db
# Option B : MySQL/MariaDB locale (docker-compose expose MariaDB sur le port 3307)
DB_NAME=gestion_paroissiale_db
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3307

# --- Redis (jetons JWT, cache, verrouillage de compte) ----------------------
# docker-compose expose Redis sur le port 6380. Laisser vide => repli LocMemCache.
REDIS_URL=redis://127.0.0.1:6380/0

# --- E-mail -----------------------------------------------------------------
# Backend principal : Resend via django-anymail (seul backend qui fonctionne en
# production sur Render - le SMTP sortant y est bloqué).
EMAIL_BACKEND=anymail.backends.resend.EmailBackend
RESEND_API_KEY=re_votre_cle_api_resend
FROM_EMAIL=Paroisse <no-reply@votre-domaine.com>
TEST_RECIPIENT=vous@exemple.com

# Repli SMTP (développement uniquement ; mettre EMAIL_FALLBACK_BACKEND="" pour désactiver)
EMAIL_FALLBACK_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_SSL=False
EMAIL_HOST_USER=vous@gmail.com
EMAIL_HOST_PASSWORD=mot-de-passe-application

# --- URLs publiques ---------------------------------------------------------
# Base des liens envoyés par e-mail (vérification, réinitialisation)
PUBLIC_BASE_URL=http://127.0.0.1:8000/api
# URL du frontend (CORS / redirections)
FRONTEND_URL=http://localhost:3000

# --- Production uniquement --------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://votre-frontend.com
# CSRF_TRUSTED_ORIGINS=https://votre-api.onrender.com
